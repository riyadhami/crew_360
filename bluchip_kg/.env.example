# ── Cosmos DB (Gremlin API) ───────────────────────────────────────────────────
# Endpoint WITHOUT the wss:// prefix and WITHOUT the port
# Example: myaccount.gremlin.cosmos.azure.com
COSMOS_DB_ENDPOINT=your-account.gremlin.cosmos.azure.com

# Primary key from the Azure Portal → Cosmos DB → Keys
COSMOS_DB_KEY=your-primary-key==

# Database and graph container names (create these in Azure Portal first)
COSMOS_DB_DATABASE=BluChipKG
COSMOS_DB_GRAPH=BluChip_360

# ── Azure OpenAI (optional – only needed if you add LLM agents later) ─────────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
